rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function memberPath(roomId, uid) {
      return /databases/$(database)/documents/rooms/$(roomId)/members/$(uid);
    }

    function roomPath(roomId) {
      return /databases/$(database)/documents/rooms/$(roomId);
    }

    function isRoomMember(roomId) {
      return signedIn() && exists(memberPath(roomId, request.auth.uid));
    }

    function isRoomOwner(roomId) {
      return signedIn()
        && exists(roomPath(roomId))
        && get(roomPath(roomId)).data.ownerUid == request.auth.uid;
    }

    function visibleCoupon(data) {
      return data.visibility == "room" || data.ownerUid == request.auth.uid;
    }

    function immutableCouponFields() {
      return request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.imageBlobPath == resource.data.imageBlobPath
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function ownerCanEditCoupon() {
      return resource.data.ownerUid == request.auth.uid
        && immutableCouponFields()
        && visibleCoupon(request.resource.data);
    }

    function memberCanReserve() {
      return resource.data.status == "active"
        && request.resource.data.status == "reserved"
        && request.resource.data.reservedByUid == request.auth.uid
        && request.resource.data.usedByUid == resource.data.usedByUid
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["status", "reservedByUid", "updatedAt"]);
    }

    function memberCanCancelReservation() {
      return resource.data.status == "reserved"
        && request.resource.data.status == "active"
        && request.resource.data.reservedByUid == null
        && (resource.data.reservedByUid == request.auth.uid || resource.data.ownerUid == request.auth.uid)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["status", "reservedByUid", "updatedAt"]);
    }

    function memberCanMarkUsed() {
      return (resource.data.status == "active" || resource.data.status == "reserved")
        && request.resource.data.status == "used"
        && request.resource.data.usedByUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["status", "usedByUid", "usedAt", "updatedAt"]);
    }

    match /users/{uid} {
      allow read: if isSelf(uid);
      allow create, update: if isSelf(uid)
        && request.resource.data.keys().hasOnly([
          "displayName", "email", "photoUrl", "defaultNotificationMode",
          "defaultNotificationDays", "pushEnabled", "createdAt", "updatedAt"
        ]);
      allow delete: if false;

      match /pushTokens/{tokenId} {
        allow read, create, update, delete: if isSelf(uid);
      }

      match /roomMemberships/{roomId} {
        allow read: if isSelf(uid);
        allow create, update, delete: if false;
      }
    }

    match /rooms/{roomId} {
      allow read: if isRoomMember(roomId);
      allow create, delete: if false;
      allow update: if isRoomOwner(roomId)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["defaultNotificationMode", "defaultNotificationDays", "updatedAt"]);

      match /members/{uid} {
        allow read: if isRoomMember(roomId);
        allow create, delete: if false;
        allow update: if isSelf(uid)
          && isRoomMember(roomId)
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["notificationEnabled", "notificationMode", "notificationDays", "updatedAt"]);
      }

      match /coupons/{couponId} {
        allow read: if isRoomMember(roomId) && visibleCoupon(resource.data);
        allow create: if isRoomMember(roomId)
          && request.resource.data.ownerUid == request.auth.uid
          && request.resource.data.status == "active"
          && request.resource.data.timezone == "Asia/Seoul"
          && request.resource.data.imageBlobPath is string
          && visibleCoupon(request.resource.data);
        allow update: if isRoomMember(roomId)
          && visibleCoupon(resource.data)
          && (ownerCanEditCoupon() || memberCanReserve() || memberCanCancelReservation() || memberCanMarkUsed());
        allow delete: if false;
      }
    }

    match /notificationLogs/{logId} {
      allow read, write: if false;
    }

    match /roomSecrets/{roomId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
